---
import { siteConfig } from '@/config';
import { isLocale, DEFAULT_LOCALE, prefixFor, type Locale } from '@/i18n/config';
import { getDictionary, makeT } from '@/i18n/load';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BackToTop from '@/components/BackToTop.astro';
import Search from '@/components/Search.astro';
import SettingsPanel from '@/components/SettingsPanel.astro';
import LangSwitcher from '@/components/LangSwitcher.astro';
import '@/styles/global.css';
import '@/styles/interactivity.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  lang?: Locale;
  includeKatex?: boolean;
}

const { title, description, canonical, lang, includeKatex = false } = Astro.props;
const enabled = siteConfig.i18n.enabled;

const currentLocale: Locale = enabled
  ? (lang && isLocale(lang) ? lang : DEFAULT_LOCALE)
  : DEFAULT_LOCALE;
const t = enabled ? makeT(getDictionary(currentLocale)) : null;

const navItems = siteConfig.nav;
const localizedNav = enabled
  ? navItems.map(item => ({ ...item, link: `/${prefixFor(currentLocale)}${item.link === '/' ? '' : item.link}` }))
  : navItems;

const siteTitle = siteConfig.title;
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || siteConfig.description;
const currentPath = Astro.url.pathname.replace(/\.html$/, '');
const htmlLang = enabled ? currentLocale : siteConfig.language;
const canonicalUrl = canonical || `${siteConfig.site}${currentPath}`;
const menuLabel = enabled && t ? t('common.menu') : 'Menu';
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />

  {enabled && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteTitle,
      inLanguage: currentLocale,
    })} />
  )}

  <!-- KaTeX CSS (only on pages with math) -->
  {includeKatex && (
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  )}

  <!-- Display font (Space Grotesk) — used only for large headings -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" /></noscript>


  <!-- Umami Analytics -->
  {siteConfig.analytics.umami.enabled && (
    <script
      defer
      src={siteConfig.analytics.umami.src}
      data-website-id={siteConfig.analytics.umami.websiteId}
    />
  )}

  <meta name="color-scheme" content="light dark" />

  <!-- Theme Init (prevent flash) -->
  <style>
    .mobile-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 9998; opacity: 0; pointer-events: none;
      transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
    :global([data-theme='dark']) .mobile-overlay { background: rgba(0,0,0,0.7); }
    .mobile-overlay:not([hidden]) { opacity: 1; pointer-events: auto; }
    .mobile-overlay[hidden] { display: block; opacity: 0; pointer-events: none; }

    .mobile-drawer {
      position: fixed; top: 0; left: 0; bottom: 0; width: 280px;
      background: #fff; z-index: 9999;
      transform: translateX(-100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      padding: 1.5rem; display: flex; flex-direction: column; gap: 0.25rem;
      box-shadow: 2px 0 12px rgba(0,0,0,0.08);
      overflow-y: auto;
      contain: layout style paint;
    }
    :global([data-theme='dark']) .mobile-drawer { background: #111; box-shadow: 2px 0 12px rgba(0,0,0,0.4); }
    .mobile-drawer.open { transform: translateX(0); }
    .mobile-drawer-header {
      display: flex; justify-content: space-between; align-items: center;
      padding-bottom: 0.75rem; margin-bottom: 0.5rem;
      border-bottom: 1px solid #ddd;
    }
    :global([data-theme='dark']) .mobile-drawer-header { border-color: #222; }
    .mobile-drawer-title { font-weight: 600; font-size: 1rem; }
    .mobile-drawer-close {
      font-size: 1.1rem; color: #999;
      padding: 2px 6px;
    }
    .mobile-drawer-close:hover { color: #000; }
    :global([data-theme='dark']) .mobile-drawer-close { color: #777; }
    :global([data-theme='dark']) .mobile-drawer-close:hover { color: #fff; }
    .mobile-link {
      display: block; padding: 0.6rem 0.5rem;
      color: #000; font-size: 1rem;
    }
    :global([data-theme='dark']) .mobile-link { color: #eee; }
    .mobile-link:hover { background: #f5f5f5; }
    :global([data-theme='dark']) .mobile-link:hover { background: #1a1a1a; }
  </style>

  <script is:inline>
    (function() {
      document.documentElement.classList.add('js');
      document.documentElement.classList.add('disable-transitions');

      function applyTheme() {
        var theme = localStorage.getItem('astro-blog-theme') || 'system';
        var resolved = theme === 'system'
          ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
          : theme;
        document.documentElement.setAttribute('data-theme', resolved);
        document.documentElement.setAttribute('data-theme-mode', theme);
        document.documentElement.style.backgroundColor = resolved === 'dark' ? '#111' : '#fff';
      }
      applyTheme();
      if (!window.__themeSwapped) {
        window.__themeSwapped = true;
        document.addEventListener('astro:before-swap', function(e) {
          var theme = localStorage.getItem('astro-blog-theme') || 'system';
          var resolved = theme === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : theme;
          e.newDocument.documentElement.setAttribute('data-theme', resolved);
          e.newDocument.documentElement.setAttribute('data-theme-mode', theme);
          e.newDocument.documentElement.style.backgroundColor = resolved === 'dark' ? '#111' : '#fff';
          document.documentElement.style.backgroundColor = resolved === 'dark' ? '#111' : '#fff';
        });
        document.addEventListener('astro:after-swap', applyTheme);
      }

      var tocVisible = localStorage.getItem('astro-blog-toc-visible');
      if (tocVisible !== null) {
        document.documentElement.setAttribute('data-toc-visible', tocVisible);
      }

      var settings = ['font-size', 'content-width', 'font-family', 'toc-visible'];
      var defaults = { 'font-size': 'medium', 'content-width': 'normal', 'font-family': 'sans', 'toc-visible': 'true' };
      for (var i = 0; i < settings.length; i++) {
        var key = settings[i];
        var val = localStorage.getItem('astro-blog-' + key) || defaults[key];
        if (val) document.documentElement.setAttribute('data-' + key, val);
      }

      requestAnimationFrame(function() {
        document.documentElement.classList.remove('disable-transitions');
      });
    })();
  </script>
</head>
<body data-locale={currentLocale}>
  <Header menuItems={localizedNav} currentLocale={currentLocale} currentPath={currentPath} t={t} />
  <Search t={t} />

  <main>
    <slot />
  </main>

  <Footer t={t} currentLocale={currentLocale} currentPath={currentPath} />

  <BackToTop t={t} />
  <SettingsPanel t={t} currentLocale={currentLocale} />

  <!-- Mobile Menu Overlay & Drawer -->
  <div class="mobile-overlay" data-mobile-overlay hidden></div>
  <div class="mobile-drawer" data-mobile-drawer>
    <div class="mobile-drawer-header">
      <span class="mobile-drawer-title">{menuLabel}</span>
      <button class="mobile-drawer-close" data-mobile-close aria-label="Close menu">✕</button>
    </div>
    {localizedNav.map((item) => (
      <a href={item.link} class="mobile-link" data-mobile-link>{item.text}</a>
    ))}
  </div>

  <script is:inline>
    (function() {
      var overlay = document.querySelector('[data-mobile-overlay]');
      var drawer = document.querySelector('[data-mobile-drawer]');
      var links = document.querySelectorAll('[data-mobile-link]');
      var closeBtn = document.querySelector('[data-mobile-close]');

      function open() {
        overlay?.removeAttribute('hidden');
        drawer?.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function close() {
        overlay?.setAttribute('hidden', '');
        drawer?.classList.remove('open');
        document.body.style.overflow = '';
      }

      document.addEventListener('mobile-menu-open', open);
      if (overlay) overlay.addEventListener('click', close);
      if (closeBtn) closeBtn.addEventListener('click', close);
      links.forEach(function(link) { link.addEventListener('click', close); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>

  <!-- Global avant-garde motion -->
  <script is:inline>
    (function () {
      function initMotion() {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        var splits = document.querySelectorAll('[data-split]');
        splits.forEach(function (el) {
          if (el.dataset.splitDone) return;
          var text = el.textContent || '';
          el.setAttribute('aria-label', text);
          var frag = document.createDocumentFragment();
          for (var i = 0; i < text.length; i++) {
            var span = document.createElement('span');
            span.className = 'char';
            span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
            span.style.setProperty('--i', String(i));
            frag.appendChild(span);
          }
          el.textContent = '';
          el.appendChild(frag);
          el.dataset.splitDone = '1';
        });

        requestAnimationFrame(function () {
          var reveals = document.querySelectorAll('[data-reveal]:not(.revealed)');
          reveals.forEach(function (el, i) {
            el.style.setProperty('--reveal-delay', i * 70 + 'ms');
            el.classList.add('revealed');
          });
        });

        if (!reduce && window.matchMedia('(hover: hover)').matches) {
          var mags = document.querySelectorAll('[data-magnetic]');
          mags.forEach(function (el) {
            if (el.dataset.magDone) return;
            el.dataset.magDone = '1';
            var rafId = null;
            el.addEventListener('mousemove', function (e) {
              if (rafId) return;
              var cx = e.clientX, cy = e.clientY;
              rafId = requestAnimationFrame(function () {
                rafId = null;
                var r = el.getBoundingClientRect();
                var x = (cx - r.left - r.width / 2) / r.width;
                var y = (cy - r.top - r.height / 2) / r.height;
                el.style.transform = 'translate(' + (x * 6).toFixed(2) + 'px, ' + (y * 6).toFixed(2) + 'px)';
              });
            });
            el.addEventListener('mouseleave', function () { if (rafId) cancelAnimationFrame(rafId); rafId = null; el.style.transform = ''; });
          });
        }

        var path = location.pathname.replace(/\/+$/, '') || '/';
        document.querySelectorAll('.nav-link').forEach(function (a) {
          var href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
          var isSiteRoot = href === '/' || /^\/[a-z]{2}(-[A-Z]{2})?$/.test(href);
          var isActive = href === path || (!isSiteRoot && path.startsWith(href + '/'));
          if (isActive) a.setAttribute('data-active', '');
          else a.removeAttribute('data-active');
        });
      }

      initMotion();
      document.addEventListener('astro:page-load', initMotion);
      document.addEventListener('i18n-applied', initMotion);
    })();
  </script>

  {enabled && (
    <script>
      import { applyI18n } from '@/i18n/runtime';
      import { isLocale, DEFAULT_LOCALE, type Locale } from '@/i18n/config';
      function bootI18n() {
        const seg = location.pathname.split('/').filter(Boolean)[0];
        const locale: Locale = (seg && isLocale(seg)) ? seg : DEFAULT_LOCALE;
        applyI18n(locale);
        document.querySelectorAll('[data-split][data-i18n]').forEach(el => {
          if (el.dataset.splitDone) delete el.dataset.splitDone;
        });
        document.dispatchEvent(new CustomEvent('i18n-applied'));
      }
      bootI18n();
      document.addEventListener('astro:page-load', bootI18n);
    </script>
  )}
</body>
</html>
