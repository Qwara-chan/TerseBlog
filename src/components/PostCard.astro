---
import { formatDate } from '@/lib/utils';

export interface Props {
  slug: string; title: string; date: string; description: string;
  tags: string[]; readingTime: number; updated?: string;
  cover?: string; featured?: boolean;
}
const { slug, title, date, description, tags, readingTime, updated, cover, featured } = Astro.props;
const showUpdated = updated && new Date(updated).getTime() - new Date(date).getTime() > 3 * 86400000;
---

<article class:list={["post-card", { featured }]} data-reveal>
  <a href={`/posts/${slug}`} class="post-link">
    {cover && (
      <div class="post-cover">
        <img src={cover} alt="" loading="lazy" />
        {featured && <span class="featured-badge">Featured</span>}
      </div>
    )}
    <div class="post-body">
      <h2 class="post-title">{title}</h2>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <time datetime={date}>{formatDate(date)}</time>
        <span class="dot">·</span>
        <span>{readingTime} min read</span>
        {showUpdated && <><span class="dot">·</span><span class="updated">Updated</span></>}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </div>
  </a>
</article>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-reveal]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const index = [...cards].indexOf(el);
        el.style.setProperty('--reveal-delay', `${index * 60}ms`);
        el.classList.add('revealed');
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  cards.forEach(card => observer.observe(card));
</script>

<style>
  .post-card {
    margin: 1.5rem 0;
    border-radius: 10px;
    background: var(--card-bg, transparent);
    border: 1px solid transparent;
    transition: transform 0.4s var(--ease-out-expo), border-color 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);

    opacity: 0;
    transform: translateY(16px);
  }
  :global([data-theme='dark']) .post-card { --card-bg: #161617; border-color: #1f1f20; }

  .post-card.revealed {
    animation: card-in 0.55s var(--ease-out-expo) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 8px 24px -8px var(--accent-soft);
  }

  .post-link {
    display: flex; flex-direction: column; gap: 0;
    text-decoration: none; color: inherit;
  }

  .post-cover {
    position: relative; overflow: hidden;
    aspect-ratio: 16 / 9;
    border-radius: 10px 10px 0 0;
    background: var(--code-bg);
  }
  .post-cover img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .post-card:hover .post-cover img { transform: scale(1.05); }

  .featured-badge {
    position: absolute; top: 12px; left: 12px;
    padding: 0.25em 0.7em;
    background: var(--accent); color: #fff;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em;
    border-radius: 999px; text-transform: uppercase;
  }

  .post-body { padding: 1.25rem 1.25rem 1.4rem; }

  .post-card.featured .post-body { padding: 1.5rem 1.5rem 1.6rem; }
  .post-card.featured .post-title { font-size: 1.45rem; }

  .post-title {
    font-size: 1.2rem; margin: 0 0 0.5rem; font-weight: 700;
    line-height: 1.35; letter-spacing: -0.01em;
  }
  .post-desc {
    color: var(--muted-strong); font-size: 0.9rem;
    line-height: 1.7; margin-bottom: 0.6rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global([data-theme='dark']) .post-desc { color: var(--muted-strong); }
  .post-meta {
    font-size: 0.78rem; color: var(--muted);
    display: flex; align-items: center; gap: 0.35rem;
    margin-bottom: 0.5rem; letter-spacing: 0.01em;
  }
  .dot { color: var(--border); }
  .updated { font-style: italic; color: var(--accent); }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.2rem; }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
