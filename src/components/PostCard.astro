---
import { formatDate } from '@/lib/utils';

export interface Props {
  slug: string; title: string; date: string; description: string;
  tags: string[]; readingTime: number; updated?: string;
}
const { slug, title, date, description, tags, readingTime, updated } = Astro.props;
const showUpdated = updated && new Date(updated).getTime() - new Date(date).getTime() > 3 * 86400000;
---

<article class="post-card" data-reveal>
  <a href={`/posts/${slug}`}>
    <h2 class="post-title">{title}</h2>
    <p class="post-desc">{description}</p>
    <div class="post-meta">
      <time datetime={date}>{formatDate(date)}</time>
      <span class="dot">·</span>
      <span>{readingTime} min</span>
      {showUpdated && <><span class="dot">·</span><span class="updated">Updated</span></>}
    </div>
    <div class="post-tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </a>
</article>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-reveal]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const index = [...cards].indexOf(el);
        el.style.setProperty('--reveal-delay', `${index * 60}ms`);
        el.classList.add('revealed');
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  cards.forEach(card => observer.observe(card));
</script>

<style>
  .post-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
    border-left: 2px solid transparent;
    padding-left: 1rem;
    margin-left: -1rem;
    transition: border-color 0.35s var(--ease-out-expo), transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-out-expo);

    opacity: 0;
    transform: translateY(16px);
  }
  :global([data-theme='dark']) .post-card { border-color: #222; }
  .post-card.revealed {
    animation: card-in 0.55s var(--ease-out-expo) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }
  .post-card:last-child { border-bottom: none; }
  .post-card:hover {
    transform: translateY(-2px);
    border-left-color: #000;
  }
  :global([data-theme='dark']) .post-card:hover { border-left-color: #eee; }
  .post-title { font-size: 1.2rem; margin: 0 0 0.4rem; }
  .post-desc { color: #666; font-size: 0.9rem; line-height: 1.7; margin-bottom: 0.5rem; }
  :global([data-theme='dark']) .post-desc { color: #999; }
  .post-meta { font-size: 0.8rem; color: #999; display: flex; align-items: center; gap: 0.3rem; margin-bottom: 0.4rem; }
  :global([data-theme='dark']) .post-meta { color: #777; }
  .dot { color: #ddd; }
  .updated { font-style: italic; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.15rem; }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
