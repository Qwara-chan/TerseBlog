---
import { siteConfig } from '@/config';
import MobileMenu from './MobileMenu.astro';
import LangSwitcher from './LangSwitcher.astro';
import type { Locale } from '@/i18n/config';

export interface Props {
  menuItems: { text: string; link: string }[];
  currentLocale?: Locale;
  currentPath?: string;
  t?: ((key: string, args?: Record<string, string | number>) => string) | null;
}
const { menuItems, currentLocale, currentPath = '/', t = null } = Astro.props;
const enabled = siteConfig.i18n.enabled;
const tt = (key: string, fallback: string) => t ? t(key) : fallback;
---

<header class="site-header">
  <div class="header-inner container">
    <a href={enabled && currentLocale ? `/${siteConfig.i18n.prefixMap[currentLocale]}` : '/'} class="site-logo">{siteConfig.title}</a>

    <nav class="desktop-nav">
      {menuItems.map((item) => (
        <a href={item.link} class="nav-link">{item.text}</a>
      ))}
    </nav>

    <div class="header-actions">
      <button class="icon-btn search-toggle" data-magnetic data-search-toggle aria-label={tt('common.search', 'Search')}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      {enabled && currentLocale && (
        <LangSwitcher currentLocale={currentLocale} currentPath={currentPath} />
      )}
      <button class="icon-btn" data-magnetic data-theme-toggle aria-label="Toggle theme">
        <svg class="theme-icon sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="theme-icon moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="theme-icon system-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <path d="M8 21h8"/>
          <path d="M12 17v4"/>
        </svg>
      </button>
      <button class="icon-btn settings-toggle" data-magnetic data-settings-toggle aria-label={tt('common.settings', 'Settings')}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
      <MobileMenu items={menuItems} t={t} />
    </div>
  </div>
</header>

<script>
  document.querySelector('[data-search-toggle]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-search'));
  });
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const themes = ['light', 'dark', 'system'];
    const cur = localStorage.getItem('astro-blog-theme') || 'system';
    const next = themes[(themes.indexOf(cur) + 1) % themes.length];
    localStorage.setItem('astro-blog-theme', next);
    const resolved = next === 'system'
      ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
      : next;
    document.documentElement.setAttribute('data-theme', resolved);
    document.documentElement.setAttribute('data-theme-mode', next);
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid #ddd;
    height: 56px;
    position: sticky; top: 0; z-index: 100;
    background: #fff;
    contain: layout style;
  }
  :global([data-theme='dark']) .site-header { border-color: #333; background: #111; }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 100%;
  }
  .site-logo { font-family: var(--font-family-display); font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; transition: color 0.3s var(--ease-out-expo); }
  .site-logo:hover { color: var(--accent); }
  .desktop-nav { display: flex; gap: 1.5rem; }
  .nav-link {
    position: relative;
    font-size: 0.85rem; color: #666; transition: color 0.3s var(--ease-out-expo);
  }
  :global([data-theme='dark']) .nav-link { color: #999; }
  .nav-link:hover { color: #000; }
  :global([data-theme='dark']) .nav-link:hover { color: #fff; }
  .nav-link::after {
    content: '';
    position: absolute; bottom: -4px; left: 0;
    width: 100%; height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s var(--ease-spring);
  }
  .nav-link:hover::after,
  .nav-link[data-active]::after { transform: scaleX(1); }
  .nav-link[data-active] { color: #000; }
  :global([data-theme='dark']) .nav-link[data-active] { color: #fff; }
  .header-actions { display: flex; align-items: center; gap: 0.25rem; }
  .icon-btn {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; color: #666;
    transition: color 0.3s var(--ease-out-expo);
  }
  :global([data-theme='dark']) .icon-btn { color: #999; }
  .icon-btn:hover { color: var(--accent); }

  :global(html[data-theme-mode='light']) .moon-icon,
  :global(html[data-theme-mode='light']) .system-icon { display: none; }
  :global(html[data-theme-mode='dark']) .sun-icon,
  :global(html[data-theme-mode='dark']) .system-icon { display: none; }
  :global(html[data-theme-mode='system']) .sun-icon,
  :global(html[data-theme-mode='system']) .moon-icon { display: none; }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
  }
</style>
