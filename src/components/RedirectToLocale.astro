---
import { siteConfig } from '@/config';
import { DEFAULT_LOCALE, prefixFor, type Locale } from '@/i18n/config';

export interface Props {
  title: string;
  description?: string;
  rest?: string;
  fallbackLocale?: Locale;
  toNotFound?: boolean;
  preserveQueryAndHash?: boolean;
}

const { title, description, rest, fallbackLocale = DEFAULT_LOCALE, toNotFound = false, preserveQueryAndHash = false } = Astro.props;
const locales = siteConfig.i18n.locales;
const prefixMap = siteConfig.i18n.prefixMap;

const prefixMapObj = Object.fromEntries(locales.map(l => [l, prefixMap[l]]));
const defaultPrefix = prefixMap[fallbackLocale];
const restValue = rest === undefined ? null : rest;

const scriptContent = [
  '(function() {',
  '  var SUPPORTED = ' + JSON.stringify(locales) + ';',
  '  var PREFIX_MAP = ' + JSON.stringify(prefixMapObj) + ';',
  '  var DEFAULT_PREFIX = ' + JSON.stringify(defaultPrefix) + ';',
  '  var FALLBACK = ' + JSON.stringify(fallbackLocale) + ';',
  '  var REST = ' + JSON.stringify(restValue) + ';',
  '  var NOT_FOUND = ' + JSON.stringify(toNotFound) + ';',
  '  var PRESERVE = ' + JSON.stringify(preserveQueryAndHash) + ';',
  '  function getCookie(n) {',
  '    var m = document.cookie.match(new RegExp("(?:^|; )" + n + "=([^;]*)"));',
  '    return m ? decodeURIComponent(m[1]) : null;',
  '  }',
  '  var cookie = getCookie("locale");',
  '  var al = navigator.language || "";',
  '  var locale = cookie;',
  '  if (!locale || SUPPORTED.indexOf(locale) === -1) {',
  '    if (/zh-Hant|zh-TW|zh-HK/i.test(al)) locale = "zh-TW";',
  '    else if (/^zh/i.test(al)) locale = "zh-CN";',
  '    else if (/^ja/i.test(al)) locale = "ja";',
  '    else if (/^en/i.test(al)) locale = "en";',
  '    else locale = FALLBACK;',
  '  }',
  '  var prefix = PREFIX_MAP[locale] || DEFAULT_PREFIX;',
  '  var suffix = PRESERVE ? (location.search + location.hash) : "";',
  '  if (NOT_FOUND) {',
  '    location.replace("/" + prefix + "/404" + suffix);',
  '    return;',
  '  }',
  '  var path = REST;',
  '  if (path === null) path = location.pathname;',
  '  path = path.replace(/\\.html$/, "").replace(/\\/+$/, "");',
  '  var seg = path.split("/").filter(Boolean)[0];',
  '  if (seg && PREFIX_MAP[seg]) {',
  '    var parts = path.split("/").filter(Boolean).slice(1);',
  '    path = parts.length ? "/" + parts.join("/") : "";',
  '  }',
  '  var target = path ? ("/" + prefix + path) : ("/" + prefix);',
  '  location.replace(target + suffix);',
  '})();',
].join('\n');
---

<!DOCTYPE html>
<html lang={fallbackLocale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    html { background: #fff; }
    :root { color-scheme: light dark; }
    @media (prefers-color-scheme: dark) { html { background: #111; } }
  </style>
</head>
<body>
  <script is:inline set:html={scriptContent}></script>
</body>
</html>
