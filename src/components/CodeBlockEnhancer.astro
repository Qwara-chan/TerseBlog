---
// Attaches a copy button to every <pre> in the article body.
// Renders nothing on its own — only injects JS that decorates code blocks.
---

<script>
  const init = () => {
    const blocks = document.querySelectorAll<HTMLPreElement>('.prose pre, article pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      pre.style.position = pre.style.position || 'relative';

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.type = 'button';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span>Copy</span>
      `;

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = (code?.innerText ?? pre.innerText).replace(/\n$/, '');
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add('copied');
          btn.querySelector('span')!.textContent = 'Copied';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.querySelector('span')!.textContent = 'Copy';
          }, 1600);
        } catch {
          btn.querySelector('span')!.textContent = 'Error';
        }
      });

      pre.appendChild(btn);
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style is:global>
  .prose pre, article pre {
    position: relative;
  }
  .copy-btn {
    position: absolute; top: 8px; right: 8px;
    display: inline-flex; align-items: center; gap: 0.35em;
    padding: 0.35em 0.7em;
    background: rgba(255, 255, 255, 0.9);
    color: #333;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.03em;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s, background 0.2s, color 0.2s;
  }
  [data-theme='dark'] .copy-btn {
    background: rgba(30, 30, 32, 0.9);
    color: #ccc;
  }
  .prose pre:hover .copy-btn,
  article pre:hover .copy-btn { opacity: 1; }
  .copy-btn:hover { transform: translateY(-1px); border-color: var(--accent); color: var(--accent); }
  .copy-btn.copied { background: var(--accent); color: #fff; border-color: var(--accent); opacity: 1; }
  @media (max-width: 600px) { .copy-btn { opacity: 1; } }
</style>
