<div class="search-overlay" data-search-overlay hidden>
  <div class="search-modal">
    <div class="search-header">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" class="search-input" data-search-input placeholder="Search posts…" autocomplete="off" />
      <button class="search-close" data-search-close aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
    <div class="search-hints"><span>↑↓ Navigate</span><span>↵ Open</span><span>Esc Close</span></div>
    <div class="search-results" data-search-results></div>
  </div>
</div>

<script>
  import { searchEngine } from '@/lib/search';
  const overlay = document.querySelector('[data-search-overlay]');
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');
  const closeBtn = document.querySelector('[data-search-close]');
  let idx = -1, timer;

  searchEngine.init();

  function open() { overlay?.removeAttribute('hidden'); input?.focus(); document.body.style.overflow = 'hidden'; }
  function close() { overlay?.setAttribute('hidden', ''); document.body.style.overflow = ''; idx = -1; if (input) input.value = ''; if (results) results.innerHTML = ''; }

  input?.addEventListener('input', e => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      if (!results) return;
      if (!e.target.value.trim()) { results.innerHTML = '<div class="search-empty">Type to search…</div>'; return; }
      const res = searchEngine.search(e.target.value);
      if (!res.length) { results.innerHTML = '<div class="search-empty">No results</div>'; return; }
      idx = -1;
      results.innerHTML = res.map((r, i) => {
        const { title, description, slug, tags } = r.item;
        return `<a href="/posts/${slug}" class="result-item" data-i="${i}">
          <div class="result-title">${searchEngine.highlight(title, e.target.value)}</div>
          <div class="result-desc">${searchEngine.highlight(description.slice(0, 120), e.target.value)}</div>
        </a>`;
      }).join('');
    }, 250);
  });

  input?.addEventListener('keydown', e => {
    const items = results?.querySelectorAll('.result-item');
    if (!items?.length) { if (e.key === 'Escape') close(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); }
    else if (e.key === 'Enter' && idx >= 0) { e.preventDefault(); items[idx]?.click(); }
    else if (e.key === 'Escape') close();
    items.forEach((el, i) => el.classList.toggle('selected', i === idx));
  });

  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', e => { if (e.target === overlay) close(); });
  document.addEventListener('open-search', open);
  document.addEventListener('keydown', e => { if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); overlay?.hasAttribute('hidden') ? open() : close(); } });
</script>

<style>
  .search-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9000; display: flex; justify-content: center; padding-top: 12vh; }
  :global([data-theme='dark']) .search-overlay { background: rgba(0,0,0,0.7); }
  .search-overlay[hidden] { display: none; }
  .search-modal { width: min(560px, 90vw); background: #fff; }
  :global([data-theme='dark']) .search-modal { background: #1a1a1a; }
  .search-header { display: flex; align-items: center; gap: 0.75rem; padding: 1rem; border-bottom: 1px solid #ddd; color: #999; }
  :global([data-theme='dark']) .search-header { border-color: #333; }
  .search-input { flex: 1; border: none; background: transparent; color: #000; font-size: 1.05rem; outline: none; }
  :global([data-theme='dark']) .search-input { color: #eee; }
  .search-close { color: #999; }
  .search-close:hover { color: #000; }
  :global([data-theme='dark']) .search-close:hover { color: #fff; }
  .search-hints { display: flex; gap: 1rem; padding: 0.4rem 1rem; font-size: 0.7rem; color: #bbb; border-bottom: 1px solid #ddd; }
  :global([data-theme='dark']) .search-hints { border-color: #333; }
  .search-results { max-height: 50vh; overflow-y: auto; }
  .search-empty { padding: 2rem; text-align: center; color: #bbb; }
  .result-item { display: block; padding: 0.75rem 1rem; border-bottom: 1px solid #eee; transition: background 0.15s; }
  :global([data-theme='dark']) .result-item { border-color: #222; }
  .result-item:hover, .result-item.selected { background: #f5f5f5; }
  :global([data-theme='dark']) .result-item:hover { background: #222; }
  :global([data-theme='dark']) .result-item.selected { background: #222; }
  .result-title { font-weight: 600; color: #000; margin-bottom: 0.15rem; font-size: 0.9rem; }
  :global([data-theme='dark']) .result-title { color: #eee; }
  .result-desc { font-size: 0.8rem; color: #888; }
  mark { background: #000; color: #fff; padding: 0.05em 0.2em; }
  :global([data-theme='dark']) mark { background: #fff; color: #111; }
</style>
