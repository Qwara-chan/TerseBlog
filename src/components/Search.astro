<div class="search-overlay" data-search-overlay hidden>
  <div class="search-modal">
    <div class="search-header">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" class="search-input" data-search-input placeholder="Search posts…" autocomplete="off" />
      <button class="search-close" data-search-close aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
    <div class="search-results" data-search-results></div>
    <div class="search-hints">
      <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
      <span><kbd>↵</kbd> Open</span>
      <span><kbd>Esc</kbd> Close</span>
    </div>
  </div>
</div>

<script>
  import { searchEngine } from '@/lib/search';
  const overlay = document.querySelector('[data-search-overlay]');
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');
  const closeBtn = document.querySelector('[data-search-close]');
  let idx = -1, timer;

  searchEngine.init();

  function open() { overlay?.removeAttribute('hidden'); input?.focus(); document.body.style.overflow = 'hidden'; }
  function close() { overlay?.setAttribute('hidden', ''); document.body.style.overflow = ''; idx = -1; if (input) input.value = ''; if (results) results.innerHTML = ''; }

  input?.addEventListener('input', e => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      if (!results) return;
      if (!e.target.value.trim()) { results.innerHTML = '<div class="search-empty">Type to search…</div>'; return; }
      const res = searchEngine.search(e.target.value);
      if (!res.length) { results.innerHTML = '<div class="search-empty">No results</div>'; return; }
      idx = -1;
      results.innerHTML = res.map((r, i) => {
        const { title, description, slug, tags, date } = r.item;
        const desc = searchEngine.highlight((description || '').slice(0, 140), e.target.value);
        const tagList = tags ? tags.split(', ').filter(Boolean) : [];
        const dateStr = date ? new Date(date).toLocaleDateString('default', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
        return `<a href="/posts/${slug}" class="result-item" data-i="${i}" style="animation-delay:${i * 30}ms">
          <div class="result-title">${searchEngine.highlight(title, e.target.value)}</div>
          ${desc ? `<div class="result-desc">${desc}</div>` : ''}
          <div class="result-meta">
            ${dateStr ? `<span class="result-date">${dateStr}</span>` : ''}
            ${tagList.length ? `<span class="result-tags">${tagList.map(t => `<span class="result-tag">${searchEngine.highlight(t, e.target.value)}</span>`).join('')}</span>` : ''}
          </div>
        </a>`;
      }).join('');
    }, 250);
  });

  input?.addEventListener('keydown', e => {
    const items = results?.querySelectorAll('.result-item');
    if (!items?.length) { if (e.key === 'Escape') close(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); }
    else if (e.key === 'Enter' && idx >= 0) { e.preventDefault(); items[idx]?.click(); }
    else if (e.key === 'Escape') close();
    items.forEach((el, i) => el.classList.toggle('selected', i === idx));
  });

  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', e => { if (e.target === overlay) close(); });
  document.addEventListener('open-search', open);
  document.addEventListener('keydown', e => { if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); overlay?.hasAttribute('hidden') ? open() : close(); } });
</script>

<style>
  .search-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.4);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    z-index: 9000;
    display: flex; justify-content: center;
    padding-top: 10vh;
    animation: overlay-in 0.2s ease;
  }
  :global([data-theme='dark']) .search-overlay { background: rgba(0,0,0,0.65); }
  .search-overlay[hidden] { display: none; }

  .search-modal {
    width: min(620px, 92vw); height: fit-content;
    max-height: 80vh;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 16px 60px rgba(0,0,0,0.15);
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  :global([data-theme='dark']) .search-modal {
    background: #181818;
    box-shadow: 0 16px 60px rgba(0,0,0,0.5);
    border: 1px solid #222;
  }

  .search-header {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem;
    color: #999;
  }
  .search-header svg { flex-shrink: 0; }
  .search-input {
    flex: 1;
    border: none; background: transparent;
    color: #000; font-size: 1.1rem;
    outline: none;
  }
  .search-input::placeholder { color: #bbb; }
  :global([data-theme='dark']) .search-input { color: #eee; }
  :global([data-theme='dark']) .search-input::placeholder { color: #555; }

  .search-close {
    display: flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 6px;
    transition: all 0.15s;
  }
  .search-close:hover { background: #f0f0f0; color: #000; }
  :global([data-theme='dark']) .search-close:hover { background: #222; color: #fff; }

  .search-hints {
    display: flex; gap: 0.75rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.7rem; color: #bbb;
    border-top: 1px solid #eee;
  }
  :global([data-theme='dark']) .search-hints { border-color: #222; }
  .search-hints kbd {
    display: inline-block;
    padding: 0.1em 0.4em;
    font-family: inherit; font-size: 0.7rem;
    border: 1px solid #ddd;
    border-radius: 3px;
    margin: 0 0.15em;
  }
  :global([data-theme='dark']) .search-hints kbd { border-color: #444; }

  .search-results {
    max-height: 55vh; overflow-y: auto;
    border-top: 1px solid #eee;
  }
  :global([data-theme='dark']) .search-results { border-color: #222; }

  .search-empty {
    padding: 3rem 1rem;
    text-align: center;
    color: #bbb;
    font-size: 0.85rem;
  }
  .search-empty svg { margin-bottom: 0.75rem; opacity: 0.3; }

  .result-item {
    display: block;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #eee;
    transition: all 0.15s;
    animation: result-in 0.2s ease both;
  }
  :global([data-theme='dark']) .result-item { border-color: #1e1e1e; }
  .result-item:hover, .result-item.selected { background: #f5f5f5; }
  :global([data-theme='dark']) .result-item:hover { background: #1a1a1a; }
  :global([data-theme='dark']) .result-item.selected { background: #1a1a1a; }
  .result-item:last-child { border-bottom: none; }

  .result-title {
    font-weight: 600;
    color: #000;
    margin-bottom: 0.15rem;
    font-size: 0.9rem;
    line-height: 1.4;
  }
  :global([data-theme='dark']) .result-title { color: #e0e0e0; }

  .result-desc {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.35rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .result-date {
    font-size: 0.7rem;
    color: #bbb;
  }
  :global([data-theme='dark']) .result-date { color: #555; }
  .result-tags { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .result-tag {
    font-size: 0.65rem;
    padding: 0.08em 0.5em;
    border: 1px solid #ddd;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #999;
  }
  :global([data-theme='dark']) .result-tag { border-color: #333; color: #777; }

  mark {
    background: #000;
    color: #fff;
    padding: 0.05em 0.2em;
  }
  :global([data-theme='dark']) mark { background: #fff; color: #111; }

  @keyframes overlay-in { from { opacity: 0; } to { opacity: 1; } }
  @keyframes result-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
</style>
