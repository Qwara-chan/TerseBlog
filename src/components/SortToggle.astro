---
import type { Locale } from '@/i18n/config';

export interface Props {
  current: 'asc' | 'desc';
  t?: ((key: string, args?: Record<string, string | number>) => string) | null;
  currentLocale?: Locale;
}
const { current, t = null, currentLocale } = Astro.props;
const tt = (key: string, fallback: string) => t ? t(key) : fallback;
const newLabel = tt('sort.newest', 'Newest');
const oldLabel = tt('sort.oldest', 'Oldest');
---

<button class="sort-toggle" data-sort-toggle data-current={current} aria-label="Toggle sort order">
  <span class="sort-label" data-newest={newLabel} data-oldest={oldLabel}>{current === 'desc' ? newLabel : oldLabel}</span>
</button>

<script>
  import { tFor, getStoredLocale, type Locale } from '@/i18n/runtime';
  import { DEFAULT_LOCALE, isLocale } from '@/i18n/config';

  function getLocale(): Locale {
    const stored = getStoredLocale();
    if (stored) return stored;
    const path = location.pathname.split('/').filter(Boolean)[0];
    return (path && isLocale(path) ? path : DEFAULT_LOCALE) as Locale;
  }

  function refreshLabel(span: HTMLElement, cur: string) {
    const locale = getLocale();
    span.textContent = cur === 'desc'
      ? tFor(locale, 'sort.newest', undefined) || 'Newest'
      : tFor(locale, 'sort.oldest', undefined) || 'Oldest';
  }

  const toggle = document.querySelector('[data-sort-toggle]') as HTMLElement | null;
  if (toggle) {
    const span = toggle.querySelector('.sort-label') as HTMLElement | null;
    toggle.addEventListener('click', () => {
      const cur = toggle.getAttribute('data-current');
      const next = cur === 'desc' ? 'asc' : 'desc';
      const url = new URL(window.location.href);
      url.searchParams.set('sort', next);
      window.history.replaceState({}, '', url);
      toggle.setAttribute('data-current', next);
      if (span) refreshLabel(span, next);
      const list = document.querySelector('[data-post-list]');
      if (!list) return;
      const items = [...list.querySelectorAll('[data-post-item]')];
      items.sort((a, b) => {
        const dA = a.getAttribute('data-post-date') || '', dB = b.getAttribute('data-post-date') || '';
        return next === 'desc' ? new Date(dB).getTime() - new Date(dA).getTime() : new Date(dA).getTime() - new Date(dB).getTime();
      });
      items.forEach(item => list.appendChild(item));
    });

    document.addEventListener('locale-change', () => {
      const cur = toggle.getAttribute('data-current') || 'desc';
      if (span) refreshLabel(span, cur);
    });
  }
</script>

<style>
  .sort-toggle { font-size: 0.8rem; color: #888; cursor: pointer; border: 1px solid #ddd; padding: 0.3em 0.8em; transition: border-color 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo); }
  :global([data-theme='dark']) .sort-toggle { border-color: #333; color: #999; }
  .sort-toggle:hover { border-color: var(--accent); color: var(--accent); }
</style>
