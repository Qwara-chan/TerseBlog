---
import { siteConfig } from '@/config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="copyright">
      &copy; {year} {siteConfig.author.name}
      {siteConfig.license.type && (
        <> · <a href={siteConfig.license.url} target="_blank" rel="noopener noreferrer">{siteConfig.license.type}</a></>
      )}
    </p>
    <div class="footer-links">
      {siteConfig.author.social.github && (
        <a href={siteConfig.author.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      )}
      {siteConfig.author.social.twitter && (
        <a href={siteConfig.author.social.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>
      )}
      <a href="/rss.xml" target="_blank">RSS</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #ddd;
    margin-top: 4rem; padding: 2rem 0;
  }
  :global([data-theme='dark']) .site-footer { border-color: #333; }
  .footer-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    text-align: center; font-size: 0.8rem; color: #888;
  }
  :global([data-theme='dark']) .footer-inner { color: #777; }
  .footer-links { display: flex; gap: 1rem; }
  .footer-links a:hover { color: #000; }
  :global([data-theme='dark']) .footer-links a:hover { color: #fff; }
</style>
