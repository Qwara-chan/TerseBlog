---
export interface Props {
  currentPage: number; totalPages: number; basePath: string;
}
const { currentPage, totalPages, basePath } = Astro.props;
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<nav class="pagination" aria-label="Pagination">
  {currentPage > 1 && (
    <a href={currentPage === 2 ? basePath : `${basePath}?page=${currentPage - 1}`} class="page-btn">← Prev</a>
  )}
  <div class="page-nums">
    {pages.map((p) => {
      const href = p === 1 ? basePath : `${basePath}?page=${p}`;
      return p === currentPage
        ? <span class="page-num current">{p}</span>
        : <a href={href} class="page-num">{p}</a>;
    })}
  </div>
  {currentPage < totalPages && (
    <a href={`${basePath}?page=${currentPage + 1}`} class="page-btn">Next →</a>
  )}
</nav>

<style>
  .pagination { display: flex; align-items: center; justify-content: center; gap: 1rem; margin: 2.5rem 0; }
  .page-nums { display: flex; gap: 0.25rem; }
  .page-num {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; font-size: 0.85rem; color: #666;
    border: 1px solid transparent; transition: all 0.2s;
  }
  :global([data-theme='dark']) .page-num { color: #999; }
  .page-num:hover { border-color: #ddd; }
  :global([data-theme='dark']) .page-num:hover { border-color: #444; }
  .page-num.current { border-color: #000; color: #000; }
  :global([data-theme='dark']) .page-num.current { border-color: #fff; color: #fff; }
  .page-btn { font-size: 0.85rem; color: #666; }
  :global([data-theme='dark']) .page-btn { color: #999; }
  .page-btn:hover { color: #000; }
  :global([data-theme='dark']) .page-btn:hover { color: #fff; }
</style>
