---
import { prefixFor, type Locale } from '@/i18n/config';

export interface Props {
  currentPage: number; totalPages: number; basePath: string;
  t?: ((key: string, args?: Record<string, string | number>) => string) | null;
  currentLocale?: Locale;
}
const { currentPage, totalPages, basePath, t = null, currentLocale } = Astro.props;
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const tt = (key: string, fallback: string) => t ? t(key) : fallback;

const localePrefix = currentLocale ? `/${prefixFor(currentLocale)}` : '';
function withLocale(p: string) { return `${localePrefix}${p === '/' ? '' : p}`; }
---

<nav class="pagination" aria-label="Pagination">
  {currentPage > 1 && (
    <a href={withLocale(currentPage === 2 ? basePath : `${basePath}?page=${currentPage - 1}`)} class="page-btn" data-i18n="pagination.prev">{tt('pagination.prev', '← Prev')}</a>
  )}
  <div class="page-nums">
    {pages.map((p) => {
      const href = withLocale(p === 1 ? basePath : `${basePath}?page=${p}`);
      return p === currentPage
        ? <span class="page-num current">{p}</span>
        : <a href={href} class="page-num">{p}</a>;
    })}
  </div>
  {currentPage < totalPages && (
    <a href={withLocale(`${basePath}?page=${currentPage + 1}`)} class="page-btn" data-i18n="pagination.next">{tt('pagination.next', 'Next →')}</a>
  )}
</nav>

<style>
  .pagination { display: flex; align-items: center; justify-content: center; gap: 1rem; margin: 2.5rem 0; }
  .page-nums { display: flex; gap: 0.25rem; flex-wrap: wrap; justify-content: center; }
  .page-num {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; font-size: 0.85rem; color: #666;
    border: 1px solid transparent; transition: border-color 0.3s var(--ease-spring), color 0.3s var(--ease-spring), transform 0.3s var(--ease-spring);
  }
  :global([data-theme='dark']) .page-num { color: #999; }
  .page-num:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
  .page-num.current { border-color: var(--accent); color: var(--accent); }
  .page-btn { font-size: 0.85rem; color: #666; transition: color 0.25s var(--ease-out-expo), transform 0.25s var(--ease-spring); }
  :global([data-theme='dark']) .page-btn { color: #999; }
  .page-btn:hover { color: var(--accent); transform: translateX(2px); }
</style>
