---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllPosts } from '@/lib/content';
import { siteConfig } from '@/config';
import RedirectToLocale from '@/components/RedirectToLocale.astro';

const enabled = siteConfig.i18n.enabled;
const allPosts = enabled ? [] : getAllPosts(import.meta.glob('../../posts/zh-CN/*.md', { eager: true }));
const tags = (() => {
  const map = new Map<string, number>();
  for (const p of allPosts) for (const t of p.tags) map.set(t, (map.get(t) || 0) + 1);
  return [...map.entries()].map(([tag, count]) => ({ tag, count })).sort((a, b) => b.count - a.count);
})();
const maxCount = Math.max(...tags.map(t => t.count), 1);
---

{enabled && <RedirectToLocale title="Tags" description="Browse all tags" rest="tags" preserveQueryAndHash />}

{enabled ? null : (
<BaseLayout title="Tags" description="Browse all tags">
  <div class="container">
    <h1 class="page-title">Tags</h1>
    <div class="tag-cloud">
      {tags.map(({ tag, count }) => (
        <a href={`/tags/${tag.toLowerCase()}`} class="tag-item" style={`--scale: ${0.8 + count / maxCount * 1.2}`}>
          {tag}<span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-title { font-family: var(--font-family-display); font-size: 1.8rem; margin: 2rem 0 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem 0.75rem; padding: 1.5rem 0; }
  .tag-item { font-size: calc(var(--scale, 1) * 0.9rem); color: #666; border: 1px solid #ddd; padding: 0.2em 0.8em; transition: border-color 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo), transform 0.3s var(--ease-spring); }
  :global([data-theme='dark']) .tag-item { color: #999; border-color: #333; }
  .tag-item:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
  .tag-count { font-size: 0.75em; color: #bbb; margin-left: 0.3em; }
</style>
)}
