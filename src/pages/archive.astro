---
import { siteConfig } from '@/config';
import BaseLayout from '@/layouts/BaseLayout.astro';
import RedirectToLocale from '@/components/RedirectToLocale.astro';
import { getAllPosts } from '@/lib/content';
import { groupPostsByYear } from '@/lib/utils';

const enabled = siteConfig.i18n.enabled;
const allPosts = enabled ? [] : getAllPosts(import.meta.glob('../posts/zh-CN/*.md', { eager: true }));
const grouped = enabled ? new Map() : groupPostsByYear(allPosts);
---

{enabled && <RedirectToLocale title="Archive" description="All posts by year" rest="archive" preserveQueryAndHash />}

{enabled ? null : (
<BaseLayout title="Archive" description="All posts by year">
  <div class="container archive">
    <h1 class="page-title" data-split>Archive</h1>
    {allPosts.length === 0 ? (
      <p class="empty">No posts yet.</p>
    ) : (
      [...grouped.entries()].map(([year, posts]) => (
        <section class="year-section" data-reveal>
          <h2 class="year">{year}</h2>
          <ul class="archive-list">
            {posts.map((post: any) => (
              <li class="archive-item">
                <time class="archive-date" datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en', { month: 'long', day: 'numeric' })}
                </time>
                <a href={`/posts/${post.slug}`} class="archive-title">{post.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </div>
</BaseLayout>

<style>
  .archive { padding: 2rem 0; max-width: calc(var(--content-width) * 5 / 6); margin: 0 auto; }
  .page-title { font-size: 1.8rem; margin-bottom: 2rem; }
  .year-section { margin-bottom: 2rem; }
  .year { font-family: var(--font-family-display); font-size: 1.3rem; margin-bottom: 0.75rem; font-weight: 700; letter-spacing: -0.02em; }
  .archive-list { list-style: none; }
  .archive-item {
    display: flex; align-items: baseline; gap: 1rem;
    padding: 0.4rem 0; border-bottom: 1px solid #eee;
  }
  :global([data-theme='dark']) .archive-item { border-color: #1a1a1a; }
  .archive-date { flex-shrink: 0; width: 110px; font-size: 0.8rem; color: #999; }
  .archive-title { font-size: 0.9rem; transition: color 0.25s var(--ease-out-expo), transform 0.25s var(--ease-spring); display: inline-block; }
  .archive-title:hover { color: var(--accent); transform: translateX(3px); }
  .empty { color: #888; text-align: center; padding: 3rem; }
  @media (max-width: 768px) { .archive-item { flex-direction: column; gap: 0.1rem; } .archive-date { width: auto; } }
</style>
)}
