---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import SortToggle from '@/components/SortToggle.astro';
import { getAllPosts, paginatePosts } from '@/lib/content';
import { siteConfig } from '@/config';

const allPosts = getAllPosts(import.meta.glob('../posts/*.md', { eager: true }));
const url = new URL(Astro.request.url);
const pageParam = url.searchParams.get('page');
const sortParam = url.searchParams.get('sort');
const currentPage = Math.max(1, parseInt(pageParam || '1') || 1);
const sorted = [...allPosts];
if (sortParam === 'asc') sorted.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

// On the first page, show featured posts in a hero strip (no duplicates below).
const showFeatured = currentPage === 1;
const featured = showFeatured ? sorted.filter(p => p.featured) : [];
const rest = showFeatured ? sorted.filter(p => !p.featured) : sorted;
const { items: posts, totalPages } = paginatePosts(rest, currentPage, siteConfig.content.postsPerPage);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <div class="container">
    <section class="hero">
      <h1 class="hero-title">{siteConfig.title}</h1>
      <p class="hero-desc">{siteConfig.description}</p>
    </section>

    {featured.length > 0 && (
      <section class="featured-strip">
        <h2 class="section-title"><span class="section-bar"></span>Featured</h2>
        {featured.map((post) => (
          <PostCard slug={post.slug} title={post.title} date={post.date}
            description={post.description} tags={post.tags}
            readingTime={post.readingTime} updated={post.updated}
            cover={post.cover} featured={true} />
        ))}
      </section>
    )}

    <div class="list-header">
      <h2 class="section-title"><span class="section-bar"></span>{featured.length > 0 ? 'Latest' : 'All Posts'}</h2>
      <div class="list-actions">
        <span class="list-count">{allPosts.length} posts</span>
        <SortToggle current={sortParam === 'asc' ? 'asc' : 'desc'} />
      </div>
    </div>

    <div class="post-list" data-post-list>
      {posts.map((post) => (
        <div data-post-item data-post-date={post.date}>
          <PostCard slug={post.slug} title={post.title} date={post.date}
            description={post.description} tags={post.tags}
            readingTime={post.readingTime} updated={post.updated}
            cover={post.cover} featured={false} />
        </div>
      ))}
    </div>

    {totalPages > 1 && <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/" />}
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center; padding: 4.5rem 0 3rem;
    border-bottom: 1px solid var(--border); margin-bottom: 2.5rem;
  }
  :global([data-theme='dark']) .hero { border-color: var(--border); }
  .hero-title {
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    margin: 0 0 0.4rem; letter-spacing: -0.04em;
    font-weight: 800; line-height: 1.1;
    background: linear-gradient(135deg, currentColor 0%, var(--accent) 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: hero-in 0.6s var(--ease-out-expo) both;
  }
  .hero-desc {
    color: var(--muted); font-size: 1rem;
    animation: hero-in 0.6s var(--ease-out-expo) 0.15s both;
  }

  .section-title {
    display: flex; align-items: center; gap: 0.6em;
    font-size: 0.85rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--muted-strong); margin: 0 0 1.25rem;
  }
  .section-bar {
    display: inline-block; width: 18px; height: 2px;
    background: var(--accent); border-radius: 2px;
  }

  .featured-strip { margin-bottom: 3rem; }

  .list-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap;
  }
  .list-header .section-title { margin-bottom: 0; }
  .list-actions { display: flex; align-items: center; gap: 1rem; }
  .list-count { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.03em; }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero { padding: 3rem 0 2rem; }
  }
</style>
