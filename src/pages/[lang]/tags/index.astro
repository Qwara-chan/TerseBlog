---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllPostsInLocale, getAllTagsInLocale } from '@/lib/content';
import { getDictionary, makeT } from '@/i18n/load';
import { LOCALES, isLocale, prefixFor } from '@/i18n/config';
import { siteConfig } from '@/config';
import type { Locale } from '@/i18n/config';

export async function getStaticPaths() {
  if (!siteConfig.i18n.enabled) return [];
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang as string)) {
  return new Response('Not found', { status: 404 });
}
const currentLocale = lang as Locale;

const t = makeT(getDictionary(currentLocale));
const tt = (key: string, args?: Record<string, string | number>) => t(key, args);

const allPosts = getAllPostsInLocale(currentLocale);
const tags = getAllTagsInLocale(currentLocale);
const maxCount = Math.max(...tags.map(t => t.count), 1);
---

<BaseLayout title="Tags" description="Browse all tags" lang={currentLocale} currentPath={Astro.url.pathname}>
  <div class="container">
    <h1 class="page-title" data-i18n="settings.toc">{tt('home.tagsLabel', 'Tags')}</h1>
    <div class="tag-cloud">
      {tags.map(({ tag, count }) => (
        <a href={`/${prefixFor(currentLocale)}/tags/${tag.toLowerCase()}`} class="tag-item" style={`--scale: ${0.8 + count / maxCount * 1.2}`}>
          {tag}<span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-title { font-family: var(--font-family-display); font-size: 1.8rem; margin: 2rem 0 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem 0.75rem; padding: 1.5rem 0; }
  .tag-item { font-size: calc(var(--scale, 1) * 0.9rem); color: #666; border: 1px solid #ddd; padding: 0.2em 0.8em; transition: border-color 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo), transform 0.3s var(--ease-spring); }
  :global([data-theme='dark']) .tag-item { color: #999; border-color: #333; }
  .tag-item:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
  .tag-count { font-size: 0.75em; color: #bbb; margin-left: 0.3em; }
</style>
