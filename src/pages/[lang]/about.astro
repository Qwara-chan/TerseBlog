---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config';
import { getDictionary, makeT } from '@/i18n/load';
import { LOCALES, isLocale } from '@/i18n/config';
import type { Locale } from '@/i18n/config';

export async function getStaticPaths() {
  if (!siteConfig.i18n.enabled) return [];
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang as string)) {
  return new Response('Not found', { status: 404 });
}
const currentLocale = lang as Locale;

const t = makeT(getDictionary(currentLocale));
const tt = (key: string, args?: Record<string, string | number>) => t(key, args);
---

<BaseLayout title="About" description="About this blog" lang={currentLocale} currentPath={Astro.url.pathname}>
  <div class="container about">
    <h1 class="page-title" data-split data-i18n="about.title">{tt('about.title')}</h1>
    <div class="about-section">
      <h2>{siteConfig.author.name}</h2>
      <p class="bio">{siteConfig.author.bio}</p>
      <div class="social">
        {siteConfig.author.social.github && <a href={siteConfig.author.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>}
        {siteConfig.author.social.twitter && <a href={siteConfig.author.social.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>}
      </div>
    </div>
    <div class="about-section">
      <h2 data-i18n="about.subtitle">{tt('about.title')}</h2>
      <p><span data-i18n="about.intro">{tt('about.intro')}</span> <a href="https://astro.build" data-i18n="about.astro">{tt('about.astro')}</a>. <span data-i18n="about.featureList">{tt('about.featureList')}</span></p>
    </div>
  </div>
</BaseLayout>

<style>
  .about { padding: 2rem 0; max-width: 600px; margin: 0 auto; }
  .page-title { font-family: var(--font-family-display); font-size: 1.8rem; margin-bottom: 2rem; font-weight: 700; letter-spacing: -0.02em; }
  .about-section { margin-bottom: 2.5rem; }
  .about-section h2 { font-size: 1.1rem; margin-bottom: 0.5rem; font-weight: 600; }
  .bio { color: #666; font-size: 0.95rem; }
  :global([data-theme='dark']) .bio { color: #999; }
  .social { display: flex; gap: 1rem; margin-top: 0.75rem; }
  .social a { font-size: 0.85rem; color: #666; transition: color 0.25s var(--ease-out-expo); position: relative; }
  :global([data-theme='dark']) .social a { color: #999; }
  .social a::after {
    content: '';
    position: absolute; bottom: -2px; left: 0;
    width: 100%; height: 1px;
    background: var(--accent);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s var(--ease-spring);
  }
  .social a:hover { color: var(--accent); }
  .social a:hover::after { transform: scaleX(1); }
  .about-section a { text-decoration: underline; }
</style>
